def test_evaluate_all_known_cards_seven_known_cards():
    """
    In this test the expected result is worked out by using the formular:
    n!/r!(n-r)! 
    n = the number of unknown cards 
    r = the number of known cards
    as a result you can compare the expected result and functions results and if there is an assertion error then it must mean the function is wrong
    this is repeated twice with two different hands 

    """
    assert pypokerprob.evaluate_all_known_cards([[3, 'spades'], [12, 'clubs'], [8, 'spades'], [5, 'diamonds'], [10, 'hearts'], [2, 'clubs'], [11, 'hearts']]) == ({'one_pair': 0,
  'two_pair': 0,
  'three_of_a_kind': 0,
  'straight': 0,
  'flush': 0,
  'full_house': 0,
  'four_of_a_kind': 0,
  'straight_flush': 0,
  'royal_flush': 0},
 1)
    assert pypokerprob.evaluate_all_known_cards([[3, 'spades'], [12, 'spades'], [8, 'spades'], [5, 'diamonds'], [10, 'spades'], [2, 'spades'], [11, 'hearts']]) == ({'one_pair': 0,
  'two_pair': 0,
  'three_of_a_kind': 0,
  'straight': 0,
  'flush': 1,
  'full_house': 0,
  'four_of_a_kind': 0,
  'straight_flush': 0,
  'royal_flush': 0},
 1)
