def best_rank_and_hand(seven_cards):
    
    best = sym.Symbol("best")
    current = sym.Symbol("current")
    current = 0
    best = -1
    best_hand = sym.Symbol("best_hand")
    best_number = sym.Symbol("best_number")
    best_number_current = sym.Symbol("best_number_current")
    for five_cards in itertools.combinations(seven_cards, 5):
        suits = [c[1] for c in five_cards]
        nums = [c[0] for c in five_cards]

        is_flush = flush_structure(five_cards)
        is_straight = straight_structure(five_cards)
        is_four = four_of_a_kind_structure(five_cards)
        is_full = full_house_structure(five_cards)
        is_three = three_of_a_kind_structure(five_cards)
        is_two_pair = two_pair_structure(five_cards)
        is_pair = one_pair_structure(five_cards)

        if is_straight and is_flush:
            current = 8
        elif is_four:
            current = 7
        elif is_full:
            current = 6
        elif is_flush:
            current = 5
        elif is_straight:
            current = 4
        elif is_three:
            current = 3
        elif is_two_pair:
            current = 2
        elif is_pair:
            current = 1
        else:
            current = 0
        current_hand = five_cards
        if current > best:
            best = current
            best_hand = five_cards
        elif  current == best:
            if best == 0 or 5:
                hand_ranks = sorted([c[0] for c in best_hand], reverse = True)
                hand_ranks_current = sorted([c[0] for c in current_hand], reverse = True)
                if hand_ranks_current[0] > hand_ranks[0]:
                    best_hand = five_cards
                elif hand_ranks_current[0] == hand_ranks[0]:
                    if hand_ranks_current[1] > hand_ranks[1]:
                        best_hand = five_cards
                    elif hand_ranks_current[1] == hand_ranks[1]:
                        if hand_ranks_current[2] > hand_ranks[2]:
                            best_hand = five_cards
                        elif hand_ranks_current[2] == hand_ranks[2]:
                            if hand_ranks_current[3] > hand_ranks[3]:
                                best_hand = five_cards
                            elif hand_ranks_current[3] == hand_ranks[3]:
                                if hand_ranks_current[4] > hand_ranks[4]:
                                    best_hand = five_cards
            elif best == 1 or 3 or 6 or 7:
                hand_ranks = sorted([c[0] for c in best_hand], reverse = True)
                hand_ranks_current = sorted([c[0] for c in current_hand], reverse = True)
                best_number = st.mode(hand_ranks)
                best_number_current = st.mode(hand_ranks_current)
                if st.mode(hand_ranks_current) > st.mode(hand_ranks):
                    best_hand = five_cards
                if st.mode(hand_ranks_current) < st.mode(hand_ranks):
                    best_hand = best_hand
                if hand_ranks_current[0] > hand_ranks[0]:
                    best_hand = five_cards
                elif hand_ranks_current[0] == hand_ranks[0]:
                    if hand_ranks_current[1] > hand_ranks[1]:
                        best_hand = five_cards
                    elif hand_ranks_current[1] == hand_ranks[1]:
                        if hand_ranks_current[2] > hand_ranks[2]:
                            best_hand = five_cards
                        elif hand_ranks_current[2] == hand_ranks[2]:
                            if hand_ranks_current[3] > hand_ranks[3]:
                                best_hand = five_cards
                            elif hand_ranks_current[3] == hand_ranks[3]:
                                if hand_ranks_current[4] > hand_ranks[4]:
                                    best_hand = five_cards
            elif best == 2:
                hand_ranks = sorted([c[0] for c in best_hand], reverse = True)
                hand_ranks_current = sorted([c[0] for c in current_hand], reverse = True)
                if st.mode(hand_ranks_current) > st.mode(hand_ranks):
                    best_hand = five_cards
                if st.mode(hand_ranks_current) < st.mode(hand_ranks):
                    best_hand = best_hand
                elif st.mode(hand_ranks_current) == st.mode(hand_ranks):
                    tie_break = list(hand_ranks)
                    tie_break_current = list(hand_ranks_current)
                    del tie_break[0: 2]
                    del tie_break_current[0: 2]
                    if st.mode(tie_break_current) > st.mode(tie_break):
                        best_hand = five_cards
                    if st.mode(tie_break_current) < st.mode(tie_break):
                        best_hand = best_hand                    
                    elif st.mode(tie_break_current) == st.mode(tie_break):
                        if hand_ranks_current[0] > hand_ranks[0]:
                            best_hand = five_cards
                        elif hand_ranks_current[0] == hand_ranks[0]:
                            if hand_ranks_current[2] > hand_ranks[2]:
                                best_hand = five_cards
                            elif hand_ranks_current[2] == hand_ranks[2]:
                                if hand_ranks_current[4] > hand_ranks[4]:
                                    best_hand = five_cards
            elif best == 4 or 8:
                hand_ranks = sorted([c[0] for c in best_hand], reverse = True)
                if hand_ranks[0] - hand_ranks[4] == 12:
                    del hand_ranks[0]
                hand_ranks_current = sorted([c[0] for c in current_hand], reverse = True)
                if hand_ranks_current[0] - hand_ranks_current[4] == 12:
                    del hand_ranks_current[0]
                if hand_ranks_current[0] > hand_ranks[0]:
                    best_hand = five_cards                                                                                
    return best, best_hand

